{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/wiki-staleness-check.sh\""
          }
        ],
        "description": "Warn when a project's linked wiki page is stale after a git commit. Opt-in via project-name: <name> in project CLAUDE.md.",
        "id": "post:bash:wiki-staleness-check"
      }
    ]
  }
}
